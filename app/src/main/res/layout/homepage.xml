<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <!-- AppBarLayout for Header and Categories that will hide/show on scroll -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="false">

        <!-- Top Header with Material Design 3 -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorPrimary"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg"
            app:layout_scrollFlags="scroll|enterAlways|snap">

            <!-- User Account Indicator with Material Design -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:gravity="end|center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:contentDescription="User profile"
                    android:src="@drawable/me"
                    app:tint="?attr/colorOnPrimary" />

                <TextView
                    android:id="@+id/userEmailIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxWidth="200dp"
                    android:maxLines="1"
                    android:text="user@email.com"
                    android:textAppearance="@style/TextAppearance.MineTeh.LabelSmall"
                    android:textColor="?attr/colorOnPrimary"
                    android:alpha="0.9" />
            </LinearLayout>

            <!-- Header Title and Subtitle with Material Typography -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/homepage_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_xs"
                    android:gravity="center"
                    android:text="@string/app_name"
                    android:textAppearance="@style/TextAppearance.MineTeh.DisplaySmall"
                    android:textColor="?attr/colorOnPrimary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Buy, Bid &amp; Sell with confidence"
                    android:textAppearance="@style/TextAppearance.MineTeh.BodyMedium"
                    android:textColor="?attr/colorOnPrimary"
                    android:alpha="0.8" />
            </LinearLayout>

            <!-- Search Bar Row with Material Design 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/recommended_touch_target"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="?attr/colorSurface"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:contentDescription="Search icon"
                    android:src="@drawable/ic_search"
                    app:tint="?attr/colorOnSurface" />

                <EditText
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Search for items, auctions..."
                    android:textAppearance="@style/TextAppearance.MineTeh.BodyMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSavedItems"
                    style="@style/Widget.MineTeh.Button.IconButton"
                    android:layout_width="@dimen/min_touch_target"
                    android:layout_height="@dimen/min_touch_target"
                    app:icon="@drawable/heart"
                    app:iconTint="?attr/colorOnSurface"
                    android:contentDescription="Saved items"
                    app:backgroundTint="@android:color/transparent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCart"
                    style="@style/Widget.MineTeh.Button.IconButton"
                    android:layout_width="@dimen/min_touch_target"
                    android:layout_height="@dimen/min_touch_target"
                    android:layout_marginStart="@dimen/spacing_xs"
                    app:icon="@drawable/cart"
                    app:iconTint="?attr/colorOnSurface"
                    android:contentDescription="Shopping cart"
                    app:backgroundTint="@android:color/transparent" />
            </LinearLayout>
        </LinearLayout>

        <!-- Categories Title and Buttons with Material Design -->
        <LinearLayout
            android:id="@+id/categoriesLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            android:orientation="vertical"
            app:layout_scrollFlags="scroll|enterAlways|snap">

            <!-- Categories Title with Material Typography -->
            <TextView
                android:id="@+id/categoriesTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="Browse Categories"
                android:textAppearance="@style/TextAppearance.MineTeh.HeadlineSmall"
                android:textColor="?attr/colorOnSurface" />

            <!-- Category Chips with Material Design -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/categoryChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="@dimen/spacing_sm">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Widget.MineTeh.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All"
                    android:checked="true"
                    android:textAppearance="@style/TextAppearance.MineTeh.LabelMedium" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipItems"
                    style="@style/Widget.MineTeh.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Items"
                    android:textAppearance="@style/TextAppearance.MineTeh.LabelMedium" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipVehicles"
                    style="@style/Widget.MineTeh.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicles"
                    android:textAppearance="@style/TextAppearance.MineTeh.LabelMedium" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipProperties"
                    style="@style/Widget.MineTeh.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Properties"
                    android:textAppearance="@style/TextAppearance.MineTeh.LabelMedium" />

            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Wrapper for RecyclerView and ProgressBar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/itemRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/spacing_md"
            android:clipToPadding="false"
            android:background="?attr/colorBackground"
            android:contentDescription="Items list" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressBar"
            style="@style/Widget.MineTeh.CircularProgressIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminate="true" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
