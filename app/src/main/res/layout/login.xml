<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface"
    tools:context=".Login">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_xl">

        <!-- App Name / Header with Material Typography -->
        <TextView
            android:id="@+id/header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/app_name"
            android:textAppearance="@style/TextAppearance.MineTeh.DisplayMedium"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Welcome Messages with Material Typography -->
        <TextView
            android:id="@+id/textView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="Welcome back to MineTeh!"
            android:textAppearance="@style/TextAppearance.MineTeh.HeadlineSmall"
            android:textColor="?attr/colorOnSurface"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_max="320dp" />

        <TextView
            android:id="@+id/textView2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="Login now to scroll, bid, and buy!"
            android:textAppearance="@style/TextAppearance.MineTeh.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/textView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_max="320dp" />

        <!-- Email Input with Material Design 3 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/email_layout"
            style="@style/Widget.MineTeh.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:hint="Email Address"
            app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
            app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
            app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
            app:boxCornerRadiusTopStart="@dimen/corner_radius_md"
            app:layout_constraintTop_toBottomOf="@id/textView2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_max="320dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/email_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textAppearance="@style/TextAppearance.MineTeh.BodyLarge"
                android:minHeight="@dimen/min_touch_target"
                android:contentDescription="Email address input" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password Input with Material Design 3 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/password_layout"
            style="@style/Widget.MineTeh.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="Password"
            app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
            app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
            app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
            app:boxCornerRadiusTopStart="@dimen/corner_radius_md"
            app:endIconMode="password_toggle"
            app:endIconContentDescription="Toggle password visibility"
            app:layout_constraintTop_toBottomOf="@id/email_layout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_max="320dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/password_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textAppearance="@style/TextAppearance.MineTeh.BodyLarge"
                android:minHeight="@dimen/min_touch_target"
                android:contentDescription="Password input" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Remember Me & Forgot Password with Material Design -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/rememberMeCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/min_touch_target"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Remember me"
            android:textAppearance="@style/TextAppearance.MineTeh.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:buttonTint="?attr/colorPrimary"
            android:contentDescription="Remember login credentials"
            app:layout_constraintTop_toBottomOf="@id/password_layout"
            app:layout_constraintStart_toStartOf="@id/password_layout" />

        <TextView
            android:id="@+id/forgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/min_touch_target"
            android:text="Forgot Password?"
            android:textAppearance="@style/TextAppearance.MineTeh.LabelMedium"
            android:textColor="?attr/colorPrimary"
            android:contentDescription="Reset password"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm"
            app:layout_constraintTop_toTopOf="@id/rememberMeCheckbox"
            app:layout_constraintBottom_toBottomOf="@id/rememberMeCheckbox"
            app:layout_constraintEnd_toEndOf="@id/password_layout" />

        <!-- Log In Button with Material Design 3 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/login_btn"
            style="@style/Widget.MineTeh.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/recommended_touch_target"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="Log in"
            android:textAppearance="@style/TextAppearance.MineTeh.LabelLarge"
            android:contentDescription="Log in to account"
            app:layout_constraintTop_toBottomOf="@id/rememberMeCheckbox"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_max="320dp" />

        <!-- Sign Up Button with Material Design 3 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/signup_btn"
            style="@style/Widget.MineTeh.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="@dimen/recommended_touch_target"
            android:layout_marginTop="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:text="Sign up"
            android:textAppearance="@style/TextAppearance.MineTeh.LabelLarge"
            android:contentDescription="Create new account"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/login_btn"
            app:layout_constraintVertical_bias="0.0"
            app:layout_constraintWidth_max="320dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
