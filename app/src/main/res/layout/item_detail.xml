<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".view.ItemDetailActivity">

    <!-- Toolbar with Back Navigation -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/black" />

    <!-- Top Purple Line from Guide -->
    <View
        android:id="@+id/topPurpleLine"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/purple_light" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Main Product Image -->
            <androidx.cardview.widget.CardView
                android:id="@+id/imageCard"
                android:layout_width="0dp"
                android:layout_height="320dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/detailItemImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_background" />
            </androidx.cardview.widget.CardView>

            <!-- Product Info Section -->
            <TextView
                android:id="@+id/detailItemName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Tzuyu Twice Official Photocard"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/imageCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/detailItemLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="123 Area Street, Dragon City"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                app:layout_constraintTop_toBottomOf="@id/detailItemName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/divider1"
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="@color/black"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/detailItemLocation" />

            <!-- Price -->
            <TextView
                android:id="@+id/detailItemPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="350.00"
                android:textColor="@color/black"
                android:textSize="26sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/divider1"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Seller Info -->
            <androidx.cardview.widget.CardView
                android:id="@+id/sellerAvatarCard"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/detailItemPrice"
                app:layout_constraintStart_toStartOf="parent">

                <ImageView
                    android:id="@+id/sellerAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_background" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/sellerName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="MagicShopbyBTS"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="@id/sellerAvatarCard"
                app:layout_constraintBottom_toBottomOf="@id/sellerAvatarCard"
                app:layout_constraintStart_toEndOf="@id/sellerAvatarCard"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/divider2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/sellerAvatarCard" />

            <!-- Action Buttons Row -->
            <ImageView
                android:id="@+id/detailHeart"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:src="@drawable/heart"
                android:padding="4dp"
                app:layout_constraintTop_toBottomOf="@id/divider2"
                app:layout_constraintStart_toStartOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToCart"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="12dp"
                android:text="Add to Cart"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:paddingHorizontal="4dp"
                app:backgroundTint="@color/purple"
                app:cornerRadius="12dp"
                app:layout_constraintTop_toTopOf="@id/detailHeart"
                app:layout_constraintBottom_toBottomOf="@id/detailHeart"
                app:layout_constraintStart_toEndOf="@id/detailHeart"
                app:layout_constraintEnd_toStartOf="@id/btnContactSeller"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContactSeller"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="Contact Seller"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:paddingHorizontal="4dp"
                app:backgroundTint="@color/purple"
                app:cornerRadius="12dp"
                app:layout_constraintTop_toTopOf="@id/detailHeart"
                app:layout_constraintBottom_toBottomOf="@id/detailHeart"
                app:layout_constraintStart_toEndOf="@id/btnAddToCart"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuyNow"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:text="Buy Now"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="@color/purple"
                app:cornerRadius="12dp"
                app:layout_constraintTop_toBottomOf="@id/btnAddToCart"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/divider3"
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="@color/black"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/btnBuyNow" />

            <!-- Description / Bullet Points -->
            <TextView
                android:id="@+id/detailItemDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="6dp"
                android:text="• Photocard with Acrylic Holder\n• Stored safely in a sleeve\n• Original / Official merchandise"
                android:textColor="@color/black"
                android:textSize="18sp"
                app:layout_constraintTop_toBottomOf="@id/divider3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:paddingBottom="32dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
