<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".view.ItemDetailActivity">

    <!-- Toolbar with Back Navigation -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/black" />

    <!-- Top Purple Line -->
    <View
        android:id="@+id/topPurpleLine"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/purple_light" />

    <!-- Content Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Loading State -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- Error State -->
        <LinearLayout
            android:id="@+id/errorLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">
            
            <TextView
                android:id="@+id/errorMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Failed to load listing"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:gravity="center" />
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Retry"
                app:backgroundTint="@color/purple" />
        </LinearLayout>

        <!-- Content State -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Image Carousel -->
                <FrameLayout
                    android:id="@+id/imageCarouselContainer"
                    android:layout_width="match_parent"
                    android:layout_height="320dp">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/imageCarousel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <TextView
                        android:id="@+id/imagePosition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="12dp"
                        android:text="1 / 1"
                        android:background="@drawable/image_counter_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textColor="@color/white"
                        android:textSize="12sp" />
                </FrameLayout>

                <!-- Badges Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="start"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/badgeCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Category"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/badge_category_background"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/badgeCondition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="New"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/badge_condition_background"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/badgeListingType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auction"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/badge_listing_type_background"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/auctionStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="LIVE"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/circle_background_red"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Title Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/detailItemName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Loading..."
                        android:textColor="@color/black"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/btnShare"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_share"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp"
                        android:contentDescription="Share" />
                </LinearLayout>

                <!-- Owner Badge -->
                <TextView
                    android:id="@+id/ownerBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Your Listing"
                    android:textColor="@color/purple"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/your_listing_badge_bg"
                    android:visibility="gone" />

                <!-- Location -->
                <TextView
                    android:id="@+id/detailItemLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text=""
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />

                <View
                    android:id="@+id/divider1"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginTop="12dp" />

                <!-- Price Card (FIXED items) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/fixedPriceCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/purple_light"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fixed Price"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/detailItemPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="₱0.00"
                            android:textColor="@color/purple"
                            android:textSize="36sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtFixedPriceNote"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Contact seller to purchase"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/detailItemPriceStub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱0.00"
                    android:textColor="@color/purple"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Bid Info Card (BID items) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/bidInfoCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="@color/purple_light">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/currentBidLabel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Current Highest Bid"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/imgLivePulse"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/circle_green"
                                android:visibility="gone"
                                android:contentDescription="Live" />

                            <TextView
                                android:id="@+id/txtBidCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 bids"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/currentBidAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="₱0.00"
                            android:textColor="@color/purple"
                            android:textSize="40sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/startingPriceLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Starting: ₱0.00"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="14dp"
                                android:layout_marginHorizontal="12dp"
                                android:background="@color/divider" />

                            <TextView
                                android:id="@+id/minimumBidIncrement"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Min increment: ₱0.00"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_lock_idle_alarm"
                                app:tint="@color/text_secondary"
                                android:contentDescription="Timer icon" />

                            <TextView
                                android:id="@+id/auctionEndTime"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Ends in: 2d 5h 30m"
                                android:textColor="@color/text_secondary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Seller Info Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/sellerAvatarCard"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="2dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/sellerAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_launcher_background"
                            android:contentDescription="Seller avatar" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/sellerName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Seller"
                            android:textColor="@color/black"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/sellerUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@username"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:id="@+id/divider2"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="16dp" />

                <!-- Action Area -->
                <LinearLayout
                    android:id="@+id/actionAreaContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <!-- BUYER: FIXED listing row -->
                    <LinearLayout
                        android:id="@+id/fixedBuyerRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/detailHeart"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/heart"
                            android:padding="4dp"
                            android:contentDescription="Favorite" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnImInterested"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="I'm Interested"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            app:backgroundTint="@color/purple"
                            app:cornerRadius="12dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnContactSeller"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Contact"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            app:backgroundTint="@color/purple"
                            app:cornerRadius="12dp" />
                    </LinearLayout>

                    <!-- Stub views for binding compatibility -->
                    <View
                        android:id="@+id/btnBuyNow"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                    <View
                        android:id="@+id/btnAddToCart"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                    <!-- BUYER: BID listing row -->
                    <LinearLayout
                        android:id="@+id/bidBuyerRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/detailHeartBid"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/heart"
                            android:padding="4dp"
                            android:contentDescription="Favorite" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPlaceBid"
                            android:layout_width="0dp"
                            android:layout_height="64dp"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="Place Bid"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            app:icon="@android:drawable/ic_input_add"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp"
                            app:backgroundTint="@color/purple"
                            app:cornerRadius="12dp" />
                    </LinearLayout>

                    <!-- BID Contact Seller button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnContactSellerBid"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="12dp"
                        android:text="Contact Seller"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:backgroundTint="@color/purple"
                        app:cornerRadius="12dp" />

                    <!-- OWNER: Management Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/ownerManagementCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/purple"
                        app:strokeWidth="1.5dp"
                        app:cardBackgroundColor="@color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="14dp">

                                <View
                                    android:layout_width="4dp"
                                    android:layout_height="20dp"
                                    android:background="@color/purple"
                                    android:layout_marginEnd="10dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Manage Listing"
                                    android:textColor="@color/black"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnEditListing"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:text="Edit Listing"
                                android:textSize="14sp"
                                android:textAllCaps="false"
                                android:textColor="@color/purple"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:layout_marginBottom="10dp"
                                app:strokeColor="@color/purple"
                                app:strokeWidth="1.5dp"
                                app:cornerRadius="8dp"
                                app:icon="@drawable/ic_edit"
                                app:iconTint="@color/purple"
                                app:iconSize="18dp"
                                app:iconPadding="8dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnViewYourListings"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:text="View All My Listings"
                                android:textSize="14sp"
                                android:textAllCaps="false"
                                android:textColor="@color/purple"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:layout_marginBottom="10dp"
                                app:strokeColor="@color/purple"
                                app:strokeWidth="1.5dp"
                                app:cornerRadius="8dp"
                                app:icon="@drawable/sell"
                                app:iconTint="@color/purple"
                                app:iconSize="18dp"
                                app:iconPadding="8dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCloseAuction"
                                style="@style/Widget.MaterialComponents.Button"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:text="Close Auction"
                                android:textSize="14sp"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:visibility="gone"
                                android:layout_marginBottom="10dp"
                                app:backgroundTint="#FF9800"
                                app:cornerRadius="8dp"
                                app:iconSize="18dp"
                                app:iconPadding="8dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnToggleStatus"
                                style="@style/Widget.MaterialComponents.Button"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:text="Disable Listing"
                                android:textSize="14sp"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                app:backgroundTint="#dc3545"
                                app:cornerRadius="8dp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Divider before description -->
                    <View
                        android:id="@+id/divider3"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginTop="16dp"
                        android:visibility="gone" />

                    <!-- Description -->
                    <TextView
                        android:id="@+id/detailItemDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:lineSpacingExtra="6dp"
                        android:text=""
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:paddingBottom="32dp" />

                </LinearLayout>

                <!-- Stubs for divider3Owner -->
                <View
                    android:id="@+id/divider3Owner"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

</LinearLayout>
