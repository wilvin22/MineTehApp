<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.MineTeh.Card.Item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/item_card_margin"
    app:cardCornerRadius="@dimen/corner_radius_md"
    app:cardElevation="@dimen/elevation_card"
    app:cardBackgroundColor="?attr/colorSurface"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:contentDescription="Item card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image Container with Loading State -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="?attr/colorSurfaceVariant">

            <!-- Item Photo with proper scaling -->
            <ImageView
                android:id="@+id/itemImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="?attr/colorSurfaceVariant"
                android:contentDescription="Item image"
                android:importantForAccessibility="yes"/>

            <!-- Loading Progress Indicator -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/imageLoadingIndicator"
                style="@style/Widget.MineTeh.CircularProgressIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminate="true" />

            <!-- Heart Icon Overlay with proper touch target -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/itemHeart"
                style="@style/Widget.MineTeh.Button.IconButton"
                android:layout_width="@dimen/min_touch_target"
                android:layout_height="@dimen/min_touch_target"
                android:layout_gravity="top|end"
                android:layout_margin="@dimen/spacing_sm"
                app:icon="@drawable/heart"
                app:iconTint="?attr/colorOnSurface"
                android:contentDescription="Add to favorites"
                android:background="@drawable/focus_indicator"
                app:backgroundTint="@android:color/transparent" />

            <!-- Type Badge (Fixed/Bid) with Material Design -->
            <com.google.android.material.chip.Chip
                android:id="@+id/itemTypeBadge"
                style="@style/Widget.MineTeh.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FIXED"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_gravity="bottom|start"
                android:layout_margin="@dimen/spacing_sm"
                app:chipBackgroundColor="?attr/colorPrimary"
                android:textColor="?attr/colorOnPrimary"
                app:chipMinHeight="24dp"
                android:clickable="false"
                android:focusable="false" />
        </FrameLayout>

        <!-- Content Section with proper spacing -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_md"
            android:orientation="vertical">

            <!-- Price with Material Typography -->
            <TextView
                android:id="@+id/itemPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="₱350"
                android:textAppearance="@style/TextAppearance.MineTeh.HeadlineSmall"
                android:textColor="?attr/colorPrimary"
                android:lines="1"
                android:ellipsize="end"
                android:contentDescription="Item price" />

            <!-- Item Name with proper hierarchy -->
            <TextView
                android:id="@+id/itemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="Item Name"
                android:textAppearance="@style/TextAppearance.MineTeh.TitleMedium"
                android:textColor="?attr/colorOnSurface"
                android:lines="2"
                android:ellipsize="end"
                android:contentDescription="Item name" />

            <!-- Location with icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_location"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Location icon" />

                <TextView
                    android:id="@+id/itemLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Manila"
                    android:textAppearance="@style/TextAppearance.MineTeh.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lines="1"
                    android:ellipsize="end"
                    android:contentDescription="Item location" />
            </LinearLayout>

            <!-- Auction Timer (Only visible for BID type) -->
            <LinearLayout
                android:id="@+id/auctionTimerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_sm"
                android:visibility="gone"
                android:background="?attr/colorErrorContainer"
                android:padding="@dimen/spacing_xs"
                app:cardCornerRadius="@dimen/corner_radius_xs">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_timer"
                    app:tint="?attr/colorOnErrorContainer"
                    android:contentDescription="Timer icon" />

                <TextView
                    android:id="@+id/itemAuctionTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2d 5h 30m"
                    android:textAppearance="@style/TextAppearance.MineTeh.LabelMedium"
                    android:textColor="?attr/colorOnErrorContainer"
                    android:textStyle="bold"
                    android:contentDescription="Time remaining" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
