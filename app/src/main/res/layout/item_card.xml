<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/white"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image Container with Gradient Overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <!-- Item Photo -->
            <ImageView
                android:id="@+id/itemImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/gray_medium"/>

            <!-- Gradient Overlay for better text readability -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/image_gradient_overlay"/>

            <!-- Heart Icon with Circular Background -->
            <FrameLayout
                android:id="@+id/heartContainer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp">
                
                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:background="@drawable/heart_circle_background"/>
                
                <ImageView
                    android:id="@+id/itemHeart"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/heart"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Favorite"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
            </FrameLayout>

            <!-- Bottom-left badges row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:elevation="2dp">

                <!-- Type Badge (Fixed/Bid) -->
                <TextView
                    android:id="@+id/itemTypeBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FIXED"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/badge_background"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp" />

                <!-- Your Listing Badge -->
                <TextView
                    android:id="@+id/yourListingBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Your Listing"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/purple"
                    android:background="@drawable/your_listing_badge_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:visibility="gone" />

            </LinearLayout>
        </FrameLayout>

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:orientation="vertical">

            <!-- Price (Top, Most Prominent) -->
            <TextView
                android:id="@+id/itemPrice"
                android:text="₱350"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/purple"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lines="1"
                android:ellipsize="end"/>

            <!-- Item Name -->
            <TextView
                android:id="@+id/itemName"
                android:text="Item Name"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"/>

            <!-- Location -->
            <TextView
                android:id="@+id/itemLocation"
                android:text="📍 Manila"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lines="1"
                android:ellipsize="end"
                android:layout_marginTop="6dp"/>

            <!-- Auction Timer (Only visible for BID type) -->
            <LinearLayout
                android:id="@+id/auctionTimerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏰"
                    android:textSize="13sp"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/itemAuctionTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2d 5h 30m"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/purple"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
