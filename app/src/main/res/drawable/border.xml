<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#FFFFFF"/>

    <!-- BORDER -->
    <stroke
        android:width="2dp"
        android:color="#666666"/>

    <!-- Rounded corners -->
    <corners android:radius="100dp"/>

    <!-- Inner spacing -->
    <padding
        android:left="12dp"
        android:top="10dp"
        android:right="12dp"
        android:bottom="10dp"/>
</shape>
